# ╔══════════════════════════════════════════════════════════════╗
# ║  Cognitive Silo — Environment Variables                      ║
# ║  Copy to .env and fill in your values:  cp .env.example .env ║
# ╚══════════════════════════════════════════════════════════════╝

# LiteLLM master key (admin access to the gateway)
LITELLM_MASTER_KEY=sk-change-me-to-something-secure

# Postgres password (LiteLLM analytics DB)
POSTGRES_PASSWORD=changeme

# HuggingFace token (needed for gated models like Fish Speech)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# GitHub Models fallback (optional — enables cloud overflow to GPT-4o)
# Create a PAT at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Open WebUI secret key (session encryption)
OPEN_WEBUI_SECRET_KEY=cognitive-silo-secret-change-me

# Open WebUI auth (set to false for single-user / LAN-only setups)
OPEN_WEBUI_AUTH=true

# ComfyUI password (ai-dock Caddy auth — login at :1111)
COMFYUI_PASSWORD=comfyui

# ComfyUI API token (shared between ComfyUI and Open WebUI for image gen)
COMFYUI_API_TOKEN=cognitive-silo-comfyui-token

# Direct address for ComfyUI login redirects (set to Tailscale IP for remote access)
# Without this, login redirects go to localhost:1111 which fails from other devices
DIRECT_ADDRESS=100.104.29.113
